{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "manifold_DIR": "C:/vcpkg/installed/x64-windows/share/manifold",
        "assimp_DIR": "C:/vcpkg/installed/x64-windows/share/assimp",
        "Clipper2_DIR": "C:/vcpkg/installed/x64-windows/share/clipper2",
        "glm_DIR": "C:/vcpkg/installed/x64-windows/share/glm",
        "GTest_DIR": "C:/vcpkg/installed/x64-windows/share/gtest",
        "TBB_DIR": "C:/vcpkg/installed/x64-windows/lib/cmake/tbb"
      }
    },
    {
      "name": "windows-x64-debug",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/out/build/x64-Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MARCSLM_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-x64-release",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/out/build/x64-Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MARCSLM_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug"
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "output": { "outputOnFailure": true }
    }
  ]
}